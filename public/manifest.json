{
  "name": "AlecRae Voice — Professional Dictation",
  "short_name": "AlecRae Voice",
  "description": "AI-powered dictation for legal and accounting professionals. Whisper transcription with Claude AI formatting, 12 document modes, and specialised legal/accounting vocabulary.",
  "id": "/app",
  "start_url": "/app",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#111920",
  "theme_color": "#111920",
  "orientation": "any",
  "categories": ["productivity", "business", "utilities"],
  "lang": "en",
  "dir": "ltr",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "id": "app.alecrae.voice"
    },
    {
      "platform": "itunes",
      "id": "app.alecrae.voice"
    }
  ],
  "icons": [
    { "src": "/icons/icon-48.png", "sizes": "48x48", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
