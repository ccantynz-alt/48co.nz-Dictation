# === Back to the Future — Environment Variables ===

# Database (Turso - primary, edge SQLite)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Database (Neon - optional, for complex queries)
DATABASE_URL=postgresql://user:pass@host/db

# AI
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Server
PORT=3001

# Sentinel (competitive intelligence)
GITHUB_TOKEN=ghp-your-github-token-here
SLACK_CRITICAL_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_DAILY_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_WEEKLY_WEBHOOK_URL=https://hooks.slack.com/services/...

# Cloudflare (edge deployment)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Modal.com (GPU workers)
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
